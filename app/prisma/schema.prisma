generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model concierges {
  id         Int         @id @default(autoincrement())
  full_name  String      @db.VarChar(100)
  email      String      @db.VarChar(100)
  shift      String?     @default("dia") @db.VarChar(20)
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  packages   packages[]
  transfers  transfers[]
}

model departments {
  id           Int         @id @default(autoincrement())
  unit_number  String      @db.VarChar(10)
  floor_number Int
  tower        String?     @default("A") @db.VarChar(10)
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  packages     packages[]
  residents    residents[]
}

model notifications {
  id          Int        @id @default(autoincrement())
  package_id  Int?
  resident_id Int?
  message     String
  is_read     Boolean?   @default(false)
  is_urgent   Boolean?   @default(false)
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  packages    packages?  @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  residents   residents? @relation(fields: [resident_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model packages {
  id            Int             @id @default(autoincrement())
  tracking_code String          @db.VarChar(50)
  description   String?
  sender_name   String?         @db.VarChar(100)
  department_id Int?
  resident_id   Int?
  concierge_id  Int?
  is_perishable Boolean?        @default(false)
  status        String?         @default("pendiente") @db.VarChar(20)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?       @default(now()) @db.Timestamp(6)
  notifications notifications[]
  concierges    concierges?     @relation(fields: [concierge_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departments   departments?    @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  residents     residents?      @relation(fields: [resident_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transfers     transfers[]
}

model residents {
  id            Int             @id @default(autoincrement())
  full_name     String          @db.VarChar(100)
  email         String          @db.VarChar(100)
  phone         String?         @db.VarChar(20)
  department_id Int?
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  password      String?         @db.VarChar(255)
  notifications notifications[]
  packages      packages[]
  departments   departments?    @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transfers     transfers[]
}

model transfers {
  id                Int         @id @default(autoincrement())
  package_id        Int?
  verification_code String      @db.VarChar(100)
  transferred_by    Int?
  received_by       Int?
  notes             String?
  created_at        DateTime?   @default(now()) @db.Timestamp(6)
  packages          packages?   @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  residents         residents?  @relation(fields: [received_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  concierges        concierges? @relation(fields: [transferred_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
